# ==========================================
# SMTP 邮件告警参数
# ==========================================
SMTP_SERVER=smtp.163.com
SMTP_PORT=465
SENDER_EMAIL=your_email@163.com
AUTH_CODE=your_smtp_auth_code
RECEIVER_EMAIL=receiver@qq.com

# ==========================================
# Duckcoding 签到参数
# ==========================================
# 登录凭证（优先使用，自动登录获取 session）
DUCK_EMAIL=your_duckcoding_email
DUCK_PASSWORD=your_duckcoding_password

# 如果已有有效的 session cookie，可直接配置（跳过登录）
SESSION_COOKIE=
NEW_API_USER=your_user_id
